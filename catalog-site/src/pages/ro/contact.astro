---
import Base from "../../layouts/Base.astro";
---
<Base title="Contact | ERMA" lang="ro">
  <main>
    <div class="contact-page">

      <h1>Contact</h1>

      <div class="contact-grid">

        <div class="contact-info">
          <h2>Telefon</h2>
          <span id="phone-numbers"></span>

          <h2>Adresă</h2>
          <address>
            ERMA Prod-Com<br>
            MIERCUREA NIRAJULUI<br>
            Str. SÂNTANA Nr. 1<br>
            Jud. MUREȘ<br>
            547410<br>
            ROMÂNIA
          </address>
        </div>

        <div class="contact-map">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2744.936505166812!2d24.80507667633261!3d46.52915827111135!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x474badb7ba4b7f39%3A0xd45918ac886410ca!2sSerele%20ERMA!5e0!3m2!1sen!2sro!4v1776692218042!5m2!1sen!2sro" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>

      </div>

    </div>
  </main>

  <script is:inline>
  document.getElementById('phone-numbers').innerHTML = `
    <a href="tel:+40742651788">+40 742 651 788</a><br>
    <a href="tel:+40746213730">+40 746 213 730</a><br>
    <a href="tel:+40722456828">+40 722 456 828</a><br>
    <a href="tel:+40730107750">+40 730 107 750</a><br>
    <a href="tel:+40740094628">+40 740 094 628</a>
  `;
  </script>
</Base>

<style>
  .contact-page {
    max-width: 800px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  .contact-info h2 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .contact-info h2:first-child {
    margin-top: 0;
  }

  .contact-info address {
    font-style: normal;
    line-height: 1.8;
  }

  .contact-map iframe {
    width: 100%;
    height: 300px;
    border-radius: 8px;
    border: 0;
  }

  @media (max-width: 640px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

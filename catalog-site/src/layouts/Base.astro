---
interface Props {
  lang: "ro" | "hu";
  title?: string;
}

const { lang } = Astro.props;

const defaults = {
  ro: { title: "Erma Flori | Home",      heading: "ERMA Prod-Com — Cataloage" },
  hu: { title: "Erma Virág | Kezdőlap",  heading: "ERMA Prod-Com — Katalógusok" },
};

const title       = Astro.props.title ?? defaults[lang].title;
const heading     = defaults[lang].heading;
const pageUrl     = Astro.url.href;

const descriptions = {
  ro: "ERMA Prod-Com — distribuitor en-gros de flori, butași, mușcate și flori de balcon, în județul Mureș, România.",
  hu: "ERMA Prod-Com — virág nagykereskedés: dugványok, muskátli és erkélyvirágok nagyban, Maros megyéből, Romániából.",
};
const description = descriptions[lang];

const ogLocale = lang === "ro" ? "ro_RO" : "hu_HU";

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentPage = pathSegments[1] ?? 'home';

const navLinks = {
  ro: [
    { href: '/ro/',        label: 'Home',       page: 'home' },
    { href: '/ro/about',   label: 'Despre noi', page: 'about' },
    { href: '/ro/contact', label: 'Contact',    page: 'contact' },
  ],
  hu: [
    { href: '/hu/',        label: 'Kezdőlap', page: 'home' },
    { href: '/hu/about',   label: 'Rólunk',   page: 'about' },
    { href: '/hu/contact', label: 'Kapcsolat', page: 'contact' },
  ],
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={pageUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale"      content={ogLocale} />

    <link rel="icon" href="/favicon.ico" />

    <!-- Matomo -->
    <script is:inline>
      var _paq = window._paq = window._paq || [];
      _paq.push(["setDocumentTitle", document.domain + "/" + document.title]);
      _paq.push(["setDoNotTrack", true]);
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u="https://erma.matomo.cloud/";
        _paq.push(['setTrackerUrl', u+'matomo.php']);
        _paq.push(['setSiteId', '1']);
        var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
        g.async=true; g.src='https://cdn.matomo.cloud/erma.matomo.cloud/matomo.js';
        s.parentNode.insertBefore(g,s);
      })();
    </script>
    <!-- End Matomo Code -->

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: system-ui, sans-serif;
        background: #f5f5f2;
        color: #1a1a1a;
        min-height: 100vh;
      }

      header {
        background: white;
        color: #1a1a1a;
        padding: clamp(0.75rem, 2vw, 1.25rem) clamp(1rem, 3vw, 2rem);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem 1.5rem;
        position: sticky;
        top: 0;
        z-index: 10;
        border-top: 8px solid #7cb342;
        border-bottom: 6px solid #7cb342;
      }

      header h1 {
        font-size: clamp(1.1rem, 3vw, 1.5rem);
        font-weight: 700;
        color: #2d6a2d;
        letter-spacing: 0.02em;
      }

      .site-nav {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .site-nav a {
        color: #333;
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.75rem 1rem;
        white-space: nowrap;
      }

      .site-nav a:hover { color: #2d6a2d; }

      .site-nav a.nav-active {
        color: #2d6a2d;
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 4px;
      }

      .lang-select {
        background: transparent;
        color: #333;
        border: 1px solid #7cb342;
        border-radius: 4px;
        padding: 0.5rem 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        min-height: 2.5rem;
        cursor: pointer;
        flex-shrink: 0;
      }

      @media (max-width: 640px) {
        header { flex-wrap: wrap; row-gap: 0.5rem; }

        .site-nav { gap: 0.5rem; }

        .site-nav a {
          font-size: 0.95rem;
          padding: 0.5rem 0.6rem;
        }

        .lang-select {
          font-size: 0.9rem;
          padding: 0.35rem 0.5rem;
          min-height: 2rem;
        }
      }

      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
      }

      /* :global() is required for the rules below because these elements are
         rendered inside <slot /> by page components, not by Base.astro itself.
         Astro's scoped CSS adds a per-component data attribute to selectors, so
         styles defined here would never match elements owned by another component.
         :global() emits the selector without the scope attribute, making it apply
         across the whole page — safe here because these class names are specific. */

      :global(.type-section) h2 {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2d6a2d;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 1rem;
        padding-bottom: 0.4rem;
        border-bottom: 2px solid #2d6a2d;
      }

      /* FIX 1: auto-fill + capped max width (200px) so cards don't stretch to fill row */
      :global(.grid) {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 200px));
        gap: 1.5rem;
        list-style: none;
        justify-content: start;
      }

      :global(.card) {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.10);
        transition: box-shadow 0.15s;
      }

      :global(.card):hover { box-shadow: 0 4px 14px rgba(0,0,0,0.16); }

      :global(.card) a {
        display: block;
        text-decoration: none;
        color: inherit;
      }

      :global(.image-container) {
        width: 100%;
        aspect-ratio: 3 / 4;
        background: #f5f5f5;
        overflow: hidden;
        display: flex;
        justify-content: center;
      }

      :global(.card img) {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        display: block;
      }

      :global(.card-title) {
        padding: 0.65rem 0.75rem;
        font-size: 0.85rem;
        font-weight: 500;
        line-height: 1.35;
      }

      footer {
        text-align: center;
        padding: 1.5rem;
        font-size: 0.8rem;
        color: #888;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>{heading}</h1>
      <nav class="site-nav">
        {navLinks[lang].map(({ href, label, page }) => (
          <a href={href} class={currentPage === page ? 'nav-active' : ''}>{label}</a>
        ))}
      </nav>
      <select
        class="lang-select"
        aria-label="Limbă / Nyelv"
        onchange="var p=location.pathname.split('/');p[1]=this.value;location.pathname=p.join('/');"
      >
        <option value="ro" selected={lang === "ro"}>RO 🇷🇴</option>
        <option value="hu" selected={lang === "hu"}>HU 🇭🇺</option>
      </select>
    </header>
    <slot />
    <footer>ERMA Prod-Com &copy; {new Date().getFullYear()}</footer>
  </body>
</html>
